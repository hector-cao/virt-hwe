	if deb-systemd-helper debian-installed 'qemu-guest-agent.service'; then
		# The following line should be removed in trixie or trixie+1
		deb-systemd-helper unmask 'qemu-guest-agent.service' >/dev/null || true

		if deb-systemd-helper --quiet was-enabled 'qemu-guest-agent.service'; then
			# Create new symlinks, if any.
