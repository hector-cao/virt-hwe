	if [ -z "$DPKG_ROOT" ] && [ -x "/etc/init.d/qemu-guest-agent" ]; then
		update-rc.d qemu-guest-agent defaults >/dev/null
		if [ -n "$2" ]; then
			_dh_action=restart
		else
			_dh_action=start
		fi
		invoke-rc.d --skip-systemd-native qemu-guest-agent $_dh_action || exit 1
	fi
